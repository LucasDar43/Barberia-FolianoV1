rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, write: if request.auth != null;
    }
    match /cortes/{id} {
      allow read, write: if request.auth != null;
    }
    match /deudas/{id} {
      allow read, write: if request.auth != null;
    }
    match /cierres/{id} {
      allow read, write: if request.auth != null;
    }
    match /configuracion/{id} {
      allow read, write: if request.auth != null;
    }
    match /solicitudes/{id} {
      allow read, write: if request.auth != null;
    }
    match /bonos/{id} {
      allow read, write: if request.auth != null;
    }
    match /pagosNacho/{id} {
          allow read, write: if request.auth != null;
    }
    match /caja/{id} {
      allow read, write: if request.auth != null;
    }
    match /ventas/{id} {
      allow read, write: if request.auth != null;
    }
  }
}



